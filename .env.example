MONO_SECRET_KEY=
MONO_WEBHOOK_SECRET=
FIREBASE_PROJECT_ID=tradr-483b9
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
PORT=3000

# Termii SMS OTP — https://accounts.termii.com (API key from dashboard)
TERMII_API_KEY=
# Sender ID exactly as registered in Termii (Sender ID page). Required — omitting "from" defaults to N-Alert and often 404s if not registered.
TERMII_SENDER_ID=
# dnd = transactional (NG), generic = other routes — must match your Termii setup
TERMII_CHANNEL=dnd
